# ══════════════════════════════════════════════════════════════════
# Lightning Agent — Mainnet Environment Configuration
# Copy this to .env.mainnet and fill in all values.
# ══════════════════════════════════════════════════════════════════

# ── AI API Keys (required — at least one) ──────────────────────
# Claude API key from https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-...

# OpenRouter API key (optional failover) from https://openrouter.ai/
OPENROUTER_API_KEY=

# ── Ethereum Mainnet RPC (required for Chainlink) ─────────────
# Get from: Alchemy, Infura, QuickNode, or your own node
ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Ethereum Private Key (required for on-chain transactions) ──
# Path on HOST to directory containing a file named "eth-private-key"
# The file should contain ONLY the hex private key (no 0x prefix)
# This key signs Chainlink Functions requests, VRF, and Automation txs
# Fund it with ETH for gas and LINK for oracle subscriptions
ETH_KEY_DIR=./.eth-keys

# ── Chainlink Subscriptions (required for Functions/VRF) ───────
# Create at https://functions.chain.link/ and https://vrf.chain.link/
# Fund each subscription with LINK tokens
CHAINLINK_FUNCTIONS_SUB_ID=
CHAINLINK_VRF_SUB_ID=
CHAINLINK_DON_ID=fun-ethereum-mainnet-1
VRF_CONSUMER_ADDRESS=

# ── Lightning Network (required) ──────────────────────────────
# Your LND node REST URL (e.g., Voltage, Umbrel, or self-hosted)
LND_REST_URL=https://your-lnd-node:8080

# Path on HOST to directory containing admin.macaroon and tls.cert
# These are typically in ~/.lnd/ on your LND node
LND_DIR=./.lnd

# ── Security (all required for mainnet) ────────────────────────
# API key for authenticating requests to the Lightning Agent API
# Generate with: openssl rand -hex 32
API_KEY=

# JWT secret — minimum 32 bytes for HMAC-SHA256
# Generate with: openssl rand -base64 48
JWT_SECRET=

# AES-256-GCM key for encrypting HODL invoice preimages at rest
# Generate with: openssl rand -base64 32
ESCROW_ENCRYPTION_KEY=

# ── CORS (set to your frontend domain) ────────────────────────
CORS_ORIGIN=https://your-domain.com

# ── ACP Integration (optional) ────────────────────────────────
LITE_AGENT_API_KEY=
