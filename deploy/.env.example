# Claude AI API Key (required)
CLAUDE_API_KEY=your_claude_api_key

# Ethereum RPC URL (Sepolia testnet or mainnet)
ETH_RPC_URL=your_eth_rpc_url

# Lightning Agent API Key
API_KEY=your_api_key

# Network mode (true=testnet, false=mainnet)
IS_TESTNET=true

# ACP Agent API Key (from acp setup)
LITE_AGENT_API_KEY=your_acp_agent_api_key
